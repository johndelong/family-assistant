NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
DATA_DIR=.family-assistant
DATABASE_URL=postgres://postgres:postgres@localhost:5432/family_assistant
ENCRYPTION_MASTER_KEY=replace-with-a-32-plus-character-secret
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_DIRECT_ACTION_MODEL=
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CRON_ENABLED=true
CRON_POLL_INTERVAL_MS=30000
BRAVE_API_KEY=
ADMIN_API_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_LONG_POLL_TIMEOUT_SEC=30
