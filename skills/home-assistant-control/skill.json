{
  "name": "home-assistant-control",
  "package": {
    "version": "1.0.0",
    "apiVersion": "1",
    "author": "family-assistant",
    "tags": ["smart-home", "home-assistant", "mcp"]
  },
  "toolMatchers": {
    "idSuffixes": [
      ".HassTurnOn",
      ".HassTurnOff",
      ".HassCancelAllTimers",
      ".HassLightSet",
      ".HassBroadcast",
      ".GetDateTime",
      ".GetLiveContext"
    ],
    "idPatterns": [
      "^smart_home\\.control$"
    ]
  },
  "activation": {
    "messageAll": [
      "\\b(turn|switch|set|dim|brighten|announce|broadcast|cancel|check|status|state)\\b",
      "\\b(light|lights|lamp|lamps|dimmer|switch|switches|device|devices|timer|timers|speaker|speakers|home|house|room|rooms)\\b"
    ]
  },
  "forceIncludeMatchingTools": true,
  "structuredExecution": {
    "runtime": "constrained_tools",
    "requestModes": [
      "direct_action"
    ],
    "integrationPrompts": "matched_tools",
    "progressMessage": "Taking action..."
  },
  "executionGuards": [
    {
      "toolIdSuffix": ".HassLightSet",
      "dropFields": [
        {
          "field": "temperature",
          "whenValueEquals": 0,
          "unlessMessageMatches": "\\b(temp|temperature|kelvin|warm|cool|cooler|warmer|color)\\b"
        }
      ]
    }
  ]
}
