{
  "name": "family-assistant-workspace",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm --filter @family-assistant/runtime build && pnpm --filter @family-assistant/frontend build",
    "dev": "pnpm runtime:dev",
    "runtime:dev": "pnpm --filter @family-assistant/runtime dev",
    "frontend:dev": "pnpm --filter @family-assistant/frontend dev",
    "frontend:build": "pnpm --filter @family-assistant/frontend build",
    "frontend:start": "pnpm --filter @family-assistant/frontend start",
    "start": "pnpm --filter @family-assistant/runtime start",
    "typecheck": "pnpm --filter @family-assistant/runtime typecheck && pnpm --filter @family-assistant/frontend typecheck && pnpm --filter @family-assistant/runtime exec tsc --noEmit -p ../tsconfig.extensions.json"
  }
}
